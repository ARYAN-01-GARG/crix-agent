{
  "name": "@crix/worker",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone BullMQ agent worker for crix server mode",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "start": "node dist/index.js",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@crix/cache": "workspace:*",
    "@crix/context": "workspace:*",
    "@crix/core": "workspace:*",
    "@crix/events": "workspace:*",
    "@crix/harness": "workspace:*",
    "@crix/orchestrator": "workspace:*",
    "@crix/queue": "workspace:*",
    "@crix/shared": "workspace:*",
    "ioredis": "^5.3.2",
    "bullmq": "^5.22.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.7.3"
  }
}
